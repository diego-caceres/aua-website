# Email Configuration for Contact Form
# You need to configure these in your Vercel project settings

# SMTP Server Settings (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Contact email where messages will be sent
CONTACT_EMAIL=contacto.aidauruguay@gmail.com

# For Gmail:
# 1. Enable 2-factor authentication
# 2. Generate an "App Password" at https://myaccount.google.com/apppasswords
# 3. Use the app password as SMTP_PASS (not your regular password)
